# Copy this file to .env and fill in your own keys.
FINMIND_API_TOKEN=
FUGLE_API_KEY=

# Live dashboard snapshot cache TTL.
# Set 0 to rebuild /api/pool on every request.
DASHBOARD_CACHE_SECONDS=0

# Keep Fugle quote fast paths enabled for intraday and post-close live data.
USE_FUGLE_INTRADAY_QUOTE=1
USE_FUGLE_POST_CLOSE_QUOTE=1

# Set 0 to avoid direct TAIFEX stockLists fallback when Fugle products fail.
USE_TAIFEX_STOCK_LISTS=0
